typ b = bool
fun main() : b =
    let var b1 : b var b2 : b in
        if b1 and b2 or b1 or b2 then
            b2 and b1 and true or false
        else
            let var b1 : b var b2 : b in
                if b1 and b2 or b1 or b2 then
                    b2 and b1 and true or false
                else
                    let var b1 : b var b2 : b in
                        if b1 and b2 or b1 or b2 then
                            b2 and b1 and true or false
                        else
                            (let var b1 : b var b2 : b in
                                if b1 and b2 or b1 or b2 then
                                    b2 and b1 and true or false
                                else
                                    false
                                end
                            end,
                            let var b1 : b var b2 : b in
                                if b1 and b2 or b1 or b2 then
                                    b2 and b1 and true or false
                                else
                                    false
                                end
                            end)
                        end
                    end
                end
            end
        end
    end