fun even(n:int):bool =
    let var result:bool in
        if n == 0 then
            result = true
        else
            result = odd(n - 1)
        end,
        result
    end

fun odd(n:int):bool =
    let var result:bool in
        if n == 0 then
            result = false
        else
            result = even(n - 1)
        end,
        result
    end

fun main():int = 300