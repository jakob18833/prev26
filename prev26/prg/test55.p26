typ str = (a: bool, b:fp, c: ^str)
typ fp = (:^str:int)
fun main():int =
    let
        var arr: [100][100]fp
        var arr2: [10]fp
        var s: str
    in
        while false and s.a do (1, 1, s) end,
        s.b(s.c),
        arr[1][2](^s),
        arr2[1](^s),
        arr[1][2] = arr2[1],
        1
    end